---
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<section id="market-section" class="market-section">
  <div class="market-header">
    <div>
      <h2>Guntur Chilli Market Report</h2>
      <p class="market-location" id="marketLocation">Guntur, Andhra Pradesh</p>
    </div>
    <span class="report-date" id="reportDate">Loading...</span>
  </div>

  <div class="arrivals-card">
    <h3>Today's Arrivals</h3>
    <div class="arrivals-grid">
      <div class="arrival-item">
        <span class="arrival-label">Non-AC</span>
        <span class="arrival-value" id="nonAcArrivals">—</span>
      </div>
      <div class="arrival-item">
        <span class="arrival-label">AC</span>
        <span class="arrival-value" id="acArrivals">—</span>
      </div>
    </div>
  </div>

  <div class="prices-table-wrapper">
    <h3>Today's Prices</h3>
    <div class="table-scroll">
      <table class="market-prices-table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Variety</th>
            <th>Min (₹)</th>
            <th>Max (₹)</th>
            <th>Note</th>
          </tr>
        </thead>
        <tbody id="pricesTableBody">
          <tr>
            <td colspan="5" style="text-align:center; padding: 24px; color: #6b7280;">
              Loading prices...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="market-summary">
    <h3>Market Summary</h3>
    <ul id="marketSummaryList">
      <li>Loading...</li>
    </ul>
  </div>
</section>

<script is:inline>
  (function() {
    var API_URL = '{API_URL}';
    if (!API_URL) {
      document.getElementById('pricesTableBody').innerHTML = '<tr><td colspan="5" style="text-align:center; padding: 24px; color: #6b7280;">API not configured</td></tr>';
      return;
    }

    fetch(API_URL + '/api/prices/latest')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        document.getElementById('reportDate').textContent = data.report_date || '—';
        document.getElementById('marketLocation').textContent = (data.market || 'Guntur') + ', ' + (data.state || 'Andhra Pradesh');
        document.getElementById('nonAcArrivals').textContent = (data.arrivals && data.arrivals.non_ac) || '—';
        document.getElementById('acArrivals').textContent = (data.arrivals && data.arrivals.ac) || '—';

        var tbody = document.getElementById('pricesTableBody');
        tbody.innerHTML = '';
        if (data.prices && data.prices.length) {
          data.prices.forEach(function(p) {
            var tr = document.createElement('tr');
            var categoryClass = (p.category || '').toLowerCase().replace(/[^a-z]/g, '-');
            tr.innerHTML = '<td><span class="badge ' + categoryClass + '">' + (p.category || '') + '</span></td>' +
              '<td class="variety-name">' + (p.variety || '') + '</td>' +
              '<td class="price">₹' + Number(p.min_price || p.min || 0).toLocaleString() + '</td>' +
              '<td class="price">₹' + Number(p.max_price || p.max || 0).toLocaleString() + '</td>' +
              '<td class="note">' + (p.note || '—') + '</td>';
            tbody.appendChild(tr);
          });
        } else {
          tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding: 24px; color: #6b7280;">No prices available</td></tr>';
        }

        var summaryList = document.getElementById('marketSummaryList');
        summaryList.innerHTML = '';
        if (data.summary && data.summary.length) {
          data.summary.forEach(function(item) {
            var li = document.createElement('li');
            li.textContent = item;
            summaryList.appendChild(li);
          });
        } else {
          summaryList.innerHTML = '<li>No market summary available</li>';
        }
      })
      .catch(function(err) {
        document.getElementById('pricesTableBody').innerHTML = '<tr><td colspan="5" style="text-align:center; padding: 24px; color: #991b1b;">Failed to load prices</td></tr>';
        console.error('Failed to fetch prices:', err);
      });
  })();
</script>
