---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';
---

<BaseLayout
  title="Guntur Red Chillies Varieties - Teja, 334 Sannam, Byadgi, 341, DD | Devika Exim"
  description="Explore premium Guntur dried red chillies varieties: Teja S17, 334 Sannam, Byadgi, 341, No 5, Armoor, DD and chilli powder. Quality specifications, flavor profiles, and export-grade details from Guntur Mirchi Market."
  canonical="https://devikaexim.in/products.html"
>
  <!-- Product Description Section -->
    <div class="product-section">
      <div class="centered-heading">
        <h1>Product <span>Details</span><span class="underline"></span></h1>
      </div>
    </div>

    <div class="intro-text" style="max-width: 960px; margin: 0 auto 32px; padding: 0 24px; text-align: center; color: #4b5563; line-height: 1.7;">
      <p>Explore our complete range of premium Guntur dried red chillies and spices. Each variety has unique characteristics, heat levels, and uses. Click <strong>View Details</strong> on any product to learn more about its specifications, ASTA color values, and export availability.</p>
    </div>

    <!-- Product Cards Container -->
    <div class="product-container">
      {products.map(product => <ProductCard product={product} />)}
    </div>

  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Guntur Dry Red Chillies",
      "image": "https://devikaexim.in/assets/images/logo-no-bg.png",
      "description": "High-quality red chillies sourced from Guntur.",
      "brand": {
        "@type": "Brand",
        "name": "Devika Exim"
      },
      "offers": {
        "@type": "Offer",
        "url": "https://devikaexim.in/products.html",
        "priceCurrency": "INR",
        "price": "16000",
        "itemCondition": "https://schema.org/NewCondition",
        "availability": "https://schema.org/InStock"
      }
    }
  </script>
</BaseLayout>
