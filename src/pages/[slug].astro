---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Product {
  title: string;
  description: string;
  features: Array<{feature: string; value: string}>;
}

interface Props {
  variety: string;
  title: string;
  description: string;
  canonical: string;
  features?: Product['features'];
}

export function getStaticPaths() {
  const products: Product[] = [
  {
