---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Devika Exim - Guntur Red Chillies - Dried Red Chilli & Chilli Powder Exporters"
  description="Contact Devika Exim for inquiries on dried red chillies and chilli powder exports. Reach out to us for pricing, product details, and bulk orders. Sourced directly from the Guntur Mirchi Market."
  canonical="https://devikaexim.in/contact.html"
>
  <!-- Main Content Container -->
  <div class="info-section">
    <!-- Left Section: Message -->
    <div class="left-section">
      <h1>If you are looking for a red dry chilli variety which is not listed here, <br />
        Please do not hesitate to text, call, or send us an email.
      </h1>
    </div>

    <!-- Right Section: Contact Info -->
    <div class="right-section">
      <h5>Want to be a business owner? <br />Ask us about business opportunities at
        <a href="mailto:business@devikaexim.in">business@devikaexim.in</a>
      </h5>
      <p>
        Devika Exim <br />
        88-8-2989, Sitaramnagar, beside Mirchi Yard, NRT Road, Guntur, 522004.<br />
        Phone: +91 83413 39975<br />
        Email: <a href="mailto:info@devikaexim.in">info@devikaexim.in</a>
      </p>
    </div>
  </div>

  <!-- Contact Us Section -->

  <div class="c-container">

    <div class="row c-contact-row">
      <!-- Left Column: Social Media and Map -->
      <div class="col-md-6 social-map-column">
        <!-- Social Media Links -->
        <div class="media-row">
          <!-- Instagram -->
          <div class="social-link">
            <a href="https://www.instagram.com/guntur_red_chillies" target="_blank" rel="noreferrer"
              title="Follow Devika Exim on Instagram">
              <button class="social-btn">
                <img src="https://img.icons8.com/3d-fluency/188/instagram-new.png"
                  alt="Instagram">
                <span class="gradient-text instagram-text">Instagram</span>
              </button>
            </a>
          </div>

          <!-- Facebook -->
          <div class="social-link">
            <a href="https://www.facebook.com/srexportchilli" target="_blank" rel="noreferrer"
              title="Follow Devika Exim on Facebook">
              <button class="social-btn">
                <img src="https://img.icons8.com/fluency/96/facebook-new.png" alt="Facebook">
                <span class="gradient-text facebook-text">Facebook</span>
              </button>
            </a>
          </div>
        </div>

        <!-- Google Map Embed -->
        <div class="google-map">
          <iframe frameborder="0"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3505.4531426733097!2d80.40919957466082!3d16.293766533388645!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a4a75aab6a79f11%3A0x57d6eabe169f8d9f!2sDevika%20Exim!5e1!3m2!1sen!2sus!4v1725843342129!5m2!1sen!2sus"
            allowfullscreen="" loading="lazy"></iframe>
        </div>
      </div>

      <!-- Right Column: Contact Info & Form -->
      <div class="col-md-6 contact-column">
        <div class="text-center">
          <button type="submit" class="order-btn"
            onclick="zforms_open_window('https://forms.zohopublic.com/gunturredchillies1/form/Contactus/formperma/dRNXAbE0AMFcrUjQhR4AfgxQx3IIyKT0sUfu1ZbNWzY', 648, 700); return false;">
            Place an Order
          </button>
        </div>

        <div class="text-center contact-enquiry">
          <h4>Send in your Enquiry</h4>
          <button class="email-btn"
            onclick="zforms_open_window('https://forms.zohopublic.com/gunturredchillies1/form/Contactus/formperma/dRNXAbE0AMFcrUjQhR4AfgxQx3IIyKT0sUfu1ZbNWzY', 648, 700); return false;">
            <img src="https://img.icons8.com/fluency/250/gmail-new.png" alt="Gmail">
          </button>
        </div>

        <div class="text-center contact-whatsapp">
          <h4>Have a question? Call or text us on WhatsApp</h4>
          <a href="https://wa.me/918341339975" target="_blank" rel="noreferrer">
            <button class="whatsapp-btn">
              <img src="https://img.icons8.com/color/250/whatsapp--v1.png" alt="WhatsApp">
            </button>
          </a>
        </div>
      </div>

    </div>

  </div>

  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "mainEntity": {
        "@type": "Organization",
        "name": "Devika Exim",
        "url": "https://devikaexim.in/contact.html",
        "logo": "https://devikaexim.in/assets/images/logo-no-bg.png",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+91-8341339975",
          "contactType": "Customer Service",
          "areaServed": "worldwide",
          "availableLanguage": "English, Telugu"
        },
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "88-8-2989 Sitaramnagarn, beside Mirchi yard",
          "addressLocality": "Guntur",
          "addressRegion": "Andhra Pradesh",
          "postalCode": "522004",
          "addressCountry": "IN"
        }
      }
    }
  </script>
</BaseLayout>
