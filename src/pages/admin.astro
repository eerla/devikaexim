---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Admin - Market Report Parser"
  description="Paste raw Telegram market reports to generate structured JSON for the website."
  canonical="https://devikaexim.in/admin.html"
>
  <div class="admin-container">
    <h1>Market Report Parser</h1>
    <p class="admin-subtitle">Paste the raw Telegram text below. The parser will extract structured data for the homepage. Each parse downloads a dated archive file.</p>

    <div class="admin-form">
      <label for="raw">Raw Telegram Text</label>
      <textarea id="raw" rows="20" placeholder="Paste Telegram market report here..."></textarea>

      <div class="admin-actions">
        <button id="parseBtn" class="parse-btn">Parse & Preview</button>
        <button type="button" class="clear-btn" id="clearBtn">Clear</button>
      </div>
    </div>

    <div id="errorBox" class="error-box" style="display: none;"></div>

    <div id="previewArea" style="display: none;">
      <div class="preview-grid">
        <div class="preview-card">
          <h3>Parsed Summary</h3>
          <div class="preview-row"><span>Date:</span><strong id="pvDate">—</strong></div>
          <div class="preview-row"><span>Market:</span><strong id="pvMarket">—</strong></div>
          <div class="preview-row"><span>Arrivals:</span><strong id="pvArrivals">—</strong></div>
          <div class="preview-row"><span>Prices:</span><strong id="pvPrices">—</strong></div>
          <div class="preview-row"><span>Status:</span><strong id="pvStatus">—</strong></div>
          <div class="preview-row"><span>Summary:</span><strong id="pvSummary">—</strong></div>
        </div>

        <div class="preview-card">
          <h3>Prices Preview</h3>
          <div class="table-scroll">
            <table class="mini-table">
              <thead>
                <tr><th>Category</th><th>Variety</th><th>Min</th><th>Max</th><th>Note</th></tr>
              </thead>
              <tbody id="pvTableBody"></tbody>
            </table>
          </div>
        </div>

        <div class="preview-card full-width">
          <h3>Generated JSON</h3>
          <p class="hint">Copy this into <code>src/data/market-report.json</code></p>
          <pre class="json-output" id="pvJson"></pre>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="/assets/js/parse-market-report.browser.js"></script>
  <script is:inline>
    document.getElementById('parseBtn').addEventListener('click', function () {
      var raw = document.getElementById('raw').value;
      var errorBox = document.getElementById('errorBox');
      var previewArea = document.getElementById('previewArea');

      if (!raw.trim()) {
        errorBox.textContent = 'Please paste some Telegram text first.';
        errorBox.style.display = 'block';
        previewArea.style.display = 'none';
        return;
      }

      try {
        var parsed = window.parseMarketReport(raw);
        var json = JSON.stringify(parsed, null, 2);

        errorBox.style.display = 'none';
        previewArea.style.display = 'block';

        document.getElementById('pvDate').textContent = parsed.report_date || '—';
        document.getElementById('pvMarket').textContent = parsed.market + ', ' + parsed.state;
        document.getElementById('pvArrivals').textContent = 'Non-AC: ' + (parsed.arrivals.non_ac || '—') + ' | AC: ' + (parsed.arrivals.ac || '—');
        document.getElementById('pvPrices').textContent = parsed.prices.length + ' varieties';
        document.getElementById('pvStatus').textContent = parsed.market_status || '—';
        document.getElementById('pvSummary').textContent = parsed.summary.length + ' items';

        var tbody = document.getElementById('pvTableBody');
        tbody.innerHTML = '';
        parsed.prices.forEach(function(p) {
          var tr = document.createElement('tr');
          tr.innerHTML = '<td>' + p.category + '</td><td>' + p.variety + '</td><td>₹' + p.min.toLocaleString() + '</td><td>₹' + p.max.toLocaleString() + '</td><td>' + (p.note || '—') + '</td>';
          tbody.appendChild(tr);
        });

        document.getElementById('pvJson').textContent = json;

        var datePart = parsed.report_date ? parsed.report_date.replace(/\./g, '-') : 'unknown-date';
        window.downloadJson('market-report-' + datePart + '.json', json);
      } catch (e) {
        errorBox.textContent = 'Parse error: ' + (e.message || e);
        errorBox.style.display = 'block';
        previewArea.style.display = 'none';
      }
    });

    document.getElementById('clearBtn').addEventListener('click', function () {
      document.getElementById('raw').value = '';
      document.getElementById('errorBox').style.display = 'none';
      document.getElementById('previewArea').style.display = 'none';
    });
  </script>
</BaseLayout>
